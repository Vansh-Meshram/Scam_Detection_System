                      initial={{ strokeDashoffset: 251.3 }}
                      animate={{ strokeDashoffset: 0 }}
                      transition={{ duration: 1.5 }}
                      style={{ filter: 'drop-shadow(0 0 6px rgba(255,7,58,0.4))' }}
                    />
                    <motion.circle
